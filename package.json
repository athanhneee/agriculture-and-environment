{
  "name": "smart-farm-monitoring-system",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo cho do an INT1334 Smart Farm Monitoring System.",
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace @smart-farm/frontend run dev",
    "dev:backend": "npm --workspace @smart-farm/backend run dev",
    "build:frontend": "npm --workspace @smart-farm/frontend run build",
    "build:backend": "npm --workspace @smart-farm/backend run build",
    "test:backend": "npm --workspace @smart-farm/backend run test",
    "db:generate": "npm --workspace @smart-farm/backend run prisma:generate",
    "db:migrate": "npm --workspace @smart-farm/backend run prisma:migrate --",
    "db:seed": "npm --workspace @smart-farm/backend run prisma:seed"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "postcss": "^8.5.14",
    "next": {
      "postcss": "^8.5.14"
    }
  }
}
